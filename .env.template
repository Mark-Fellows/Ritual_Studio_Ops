# Ritual Studio Ops -- environment configuration template
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# -- Supabase ------------------------------------------------------------------
# Shared Supabase project (same project used by Teacher Management and Cover Management)
SUPABASE_URL=https://rfjygyqijwgkmxboddup.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# -- Momence API (v2 client credentials) --------------------------------------
MOMENCE_CLIENT_ID=
MOMENCE_CLIENT_SECRET=
MOMENCE_BASE_URL=https://momence.com/api/v2

# -- Momence data directory ---------------------------------------------------
# Points to the existing OneDrive folder where master CSVs live.
# Do NOT move this folder -- the Selenium scraper chain writes here.
MOMENCE_DATA_DIR=C:\Users\markj\OneDrive - MFPL\Documents\Customer Projects\Ritual\Momence_data

# -- Cloudflare Pages ---------------------------------------------------------
# Set during Phase 0 once the Pages project is created
CLOUDFLARE_PAGES_URL=https://ritual-studio-ops.pages.dev

# -- NLP / AI (Cover Management stage 2) -------------------------------------
# Primary NLP model (Claude). Used by nlp_parser.py.
ANTHROPIC_API_KEY=
NLP_MODEL=claude-haiku-4-5-20251001

# Fallback NLP model (Gemini). Used when Anthropic quota is exhausted.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -- Cover pipeline operational settings --------------------------------------
# Grade assigned to teachers auto-created by momence_teacher_sync --insert-new
INITIAL_TEACHER_GRADE=10
# How many days of Momence session history to scan in stage 1
SYNC_LOOKBACK_DAYS=365
# How many hours of WhatsApp history to scan in stage 2
WHATSAPP_LOOKBACK_HOURS=6
# Minimum NLP confidence score to auto-approve a parsed cover request
NLP_CONFIDENCE_THRESHOLD=0.70

# -- SMTP (Cover Management stage 4 email notifications) ----------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_FROM=
NOTIFY_REPLY_TO=

# -- Chrome remote debugging (Cover Management stage 2 WhatsApp scraper) ------
CHROME_DEBUG_PORT=9222
# Leave blank to use default installation path
CHROME_PATH=

# -- Feature flags ------------------------------------------------------------
# Set to true only after Phase 4 soak testing is complete for each tab
WRITES_ENABLED=false
